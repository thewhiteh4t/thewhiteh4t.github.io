---
import cves from '../data/cves.json'
import { ExternalLink } from 'lucide-react'
---

{
  cves.map((cve) => (
    <a
      href={cve.cve_url}
      target="_blank"
      rel="noopener noreferrer"
      class="no-underline group rounded-lg h-full"
    >
      <div class="h-full rounded-lg bg-surface shadow-lg shadow-black/50 p-6 flex flex-col justify-between border border-white/5 group-hover:border-cyan-300/70 transition-colors duration-200">
        <div>
          <div class="flex items-center justify-between gap-4">
            <h3 class="text-2xl">{cve.cve_id}</h3>
            <ExternalLink
              size={14}
              className="text-on-surface-variant shrink-0"
              aria-hidden="true"
            />
          </div>
          <span class="uppercase font-semibold text-red-400 text-sm mt-1 block">
            {cve.cvss}
          </span>
          <p class="mt-3 text-on-surface-variant text-sm leading-6">
            {cve.cve_title}
          </p>
        </div>
      </div>
    </a>
  ))
}
