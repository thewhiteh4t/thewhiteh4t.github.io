---
import projects from '../data/projects.json'
import { ExternalLink } from 'lucide-react'
---

{
  projects.map((project) => (
    <a
      href={project.url}
      target="_blank"
      rel="noopener noreferrer"
      class="no-underline group rounded-lg"
    >
      <div class="rounded-lg h-full bg-surface shadow-lg shadow-black/50 p-6 flex flex-col justify-between border border-white/5 group-hover:border-cyan-300 transition-colors duration-200">
        <div class="flex items-center justify-between">
          <h3 class="text-2xl">{project.title}</h3>
          <div class="flex shrink-0 items-center gap-2">
            <span class="shrink-0 text-xs font-semibold uppercase tracking-wider text-cyan-300 border border-cyan-300/30 rounded px-2 py-1">
              {project.category}
            </span>
            <ExternalLink
              size={14}
              className="text-on-surface-variant"
              aria-hidden="true"
            />
          </div>
        </div>
        <p class="text-sm text-on-surface-variant leading-6 grow mt-4">
          {project.desc}
        </p>
      </div>
    </a>
  ))
}
